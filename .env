# EduClaw 环境变量配置

# LLM 配置 — 本地 Ollama
LLM_PROVIDER=openai
LLM_MODEL=qwen3:8b
LLM_API_KEY=EMPTY
LLM_API_BASE=http://localhost:11434/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# 应用配置
DEBUG=false
APP_NAME=EduClaw

# 数据目录
DATA_DIR=./data

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=educlaw.log

# Web UI 配置
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8000
