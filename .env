# EduClaw 环境变量配置

# LLM 配置 — DeepSeek API
LLM_PROVIDER=openai
LLM_MODEL=deepseek-v4-pro
LLM_API_KEY=sk-f74dbcdd355543e992bc671a0edd6581
LLM_API_BASE=https://api.deepseek.com
LLM_TEMPERATURE=0.7
