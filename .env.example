# EduClaw 环境变量配置示例
# 复制此文件为 .env 并填入实际配置

# 应用配置
DEBUG=false
APP_NAME=EduClaw
APP_VERSION=1.0.0

# 数据目录
DATA_DIR=./data

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_FILE=educlaw.log

# LLM 配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your_api_key_here
LLM_API_BASE=https://api.openai.com/v1
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# vLLM 本地部署配置
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Telegram 配置
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=

# 飞书配置（应用机器人）
# 1. 在飞书开放平台 (https://open.feishu.cn/) 创建企业自建应用
# 2. 开启「机器人」能力
# 3. 在「事件订阅」中配置请求地址: https://your-domain/api/feishu/event
# 4. 订阅事件: im.message.receive_v1 (接收消息)
# 5. 发布版本并审批通过
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 微信配置
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# Redis 配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MongoDB 配置（可选）
MONGODB_URI=mongodb://localhost:27017/

# Web UI 配置
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8000
